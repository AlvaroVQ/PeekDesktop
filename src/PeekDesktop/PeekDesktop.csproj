<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <AssemblyName>PeekDesktop</AssemblyName>
    <RootNamespace>PeekDesktop</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Authors>Scott Hanselman</Authors>
    <Description>Click your desktop to peek at it — just like macOS Sonoma.</Description>
    <RepositoryUrl>https://github.com/shanselman/PeekDesktop</RepositoryUrl>
    <PublishAot>true</PublishAot>
    <OptimizationPreference>Size</OptimizationPreference>
    <!-- Aggressive size reduction -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <StackTraceSupport>false</StackTraceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <IlcFoldIdenticalMethodBodies>true</IlcFoldIdenticalMethodBodies>
    <EventSourceSupport>false</EventSourceSupport>
    <DebuggerSupport>false</DebuggerSupport>
    <MetadataUpdaterSupport>false</MetadataUpdaterSupport>
    <HttpActivityPropagationSupport>false</HttpActivityPropagationSupport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- VirtualDesktopService.cs is excluded under AOT because it relies on
       COM interop ([ComImport], Activator.CreateInstance) that NativeAOT
       does not support. The file is kept in the repo for future reference. -->
  <ItemGroup Condition="'$(PublishAot)' == 'true'">
    <Compile Remove="VirtualDesktopService.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="PublishAotCompressed" Version="1.0.5" />
  </ItemGroup>

</Project>
